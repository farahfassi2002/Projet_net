@page "/"
@attribute [AllowAnonymous]

<PageTitle>Portefeuille Investissement</PageTitle>

<div class="container py-5">
    <div class="row align-items-center min-vh-75">
        <div class="col-lg-6 mb-4 mb-lg-0">
            <h1 class="display-5 fw-bold text-dark mb-3">
                Gérez vos investissements <br/>
                <span class="text-primary">en toute simplicité</span>
            </h1>
            <p class="lead text-muted mb-4">
                Achetez et vendez des actions, cryptomonnaies et ETF. Suivez vos gains,
                analysez vos performances et maîtrisez votre budget d'investissement.
            </p>
            <div class="d-flex gap-3 flex-wrap">
                <a href="/login" class="btn btn-primary btn-lg px-4">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
                </a>
                <a href="/signup" class="btn btn-outline-primary btn-lg px-4">
                    <i class="bi bi-person-plus me-2"></i>Créer un compte
                </a>
            </div>
  
        </div>
       
    </div>
</div>
