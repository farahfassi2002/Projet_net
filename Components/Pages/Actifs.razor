@page "/actifs"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@inject IActifService ActifSvc
@inject ITransactionService TransactionSvc
@inject IInvestisseurService InvestisseurSvc
@inject AuthenticationStateProvider AuthState
@inject NotificationService Notify
@inject IJSRuntime JS

<PageTitle>Actifs — Portefeuille</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-briefcase-fill me-2 text-primary"></i>Gestion des actifs
    </h4>
    @if (_isAdmin)
    {
        <button class="btn btn-primary" @onclick="OpenCreateModal">
            <i class="bi bi-plus-circle me-1"></i>Nouvel actif
        </button>
    }
</div>

<!-- Filtres de recherche -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <input value="@_search" @oninput="OnSearchInput"
                       class="form-control" placeholder="🔍 Rechercher par nom ou symbole…" />
            </div>
            <div class="col-md-4">
                <select @bind="_typeFiltre" @bind:after="FiltrerActifs" class="form-select">
                    <option value="">Tous les types</option>
                    @foreach (var t in Enum.GetValues<TypeActif>())
                    {
                        <option value="@t">@t</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100" @onclick="ResetFiltres">
                    <i class="bi bi-x-circle me-1"></i>Reset
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Grille des actifs -->
@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (!_actifsFiltres.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-search fs-1 d-block mb-2"></i>
        Aucun actif trouvé.
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var actif in _actifsFiltres)
        {
            <div class="col-sm-6 col-lg-4 col-xl-3">
                <div class="card h-100 shadow-sm position-relative">
                    @if (_isAdmin)
                    {
                        <div class="position-absolute top-0 end-0 p-2">
                            <button class="btn btn-sm btn-outline-warning me-1" @onclick="() => OpenEditModal(actif)" title="Modifier">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteActif(actif)" title="Supprimer">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    }
                    <ActifCard Actif="actif"
                               OnAcheter="OuvrirModalAchat"
                               OnVendre="OuvrirModalVente" />
                </div>
            </div>
        }
    </div>
}

<!-- Modal Achat / Vente -->
@if (_actifSelectionne != null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.4)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow">
                <div class="modal-header @(_modeTransaction == TypeTransaction.Achat ? "bg-success text-white" : "bg-danger text-white")">
                    <h5 class="modal-title">
                        <i class="bi @(_modeTransaction == TypeTransaction.Achat ? "bi-cart-plus" : "bi-cash-stack") me-2"></i>
                        @_modeTransaction — @_actifSelectionne.Symbole
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="FermerModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_erreurModal))
                    {
                        <div class="alert alert-danger py-2">@_erreurModal</div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Prix unitaire (DT)</label>
                        <input type="number" @bind="_prixTransaction" class="form-control" step="0.01" min="0.0001" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Quantité</label>
                        <input type="number" @bind="_quantiteTransaction" class="form-control" step="0.0001" min="0.0001" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Statut</label>
                        <select @bind="_statutTransaction" class="form-select">
                            @foreach (var s in Enum.GetValues<StatutTransaction>())
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notes (optionnel)</label>
                        <textarea @bind="_notesTransaction" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="alert alert-light py-2 mb-0">
                        <strong>Montant total : </strong>
                        @((_prixTransaction * _quantiteTransaction).ToString("F2")) DT
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="FermerModal">Annuler</button>
                    <button class="btn @(_modeTransaction == TypeTransaction.Achat ? "btn-success" : "btn-danger")"
                            @onclick="ValiderTransaction" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Confirmer
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Création/Modification d'actif (Admin seulement) -->
@if (_showActifModal && _isAdmin)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5); z-index: 1050">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi @(_isEditActif ? "bi-pencil-square" : "bi-plus-circle") me-2"></i>
                        @(_isEditActif ? "Modifier" : "Nouvel") actif
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseActifModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_actifErrorMessage))
                    {
                        <div class="alert alert-danger py-2">@_actifErrorMessage</div>
                    }
                    <div class="mb-3">
                        <label class="form-label fw-bold">Symbole *</label>
                        <input type="text" @bind="_currentActif.Symbole" class="form-control" placeholder="ex: AAPL" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nom *</label>
                        <input type="text" @bind="_currentActif.Nom" class="form-control" placeholder="ex: Apple Inc." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Type</label>
                        <select @bind="_currentActif.Type" class="form-select">
                            @foreach (var t in Enum.GetValues<TypeActif>())
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Prix actuel (DT)</label>
                            <input type="number" @bind="_currentActif.PrixActuel" class="form-control" step="0.001" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Prix achat moyen (DT)</label>
                            <input type="number" @bind="_currentActif.PrixAchatMoyen" class="form-control" step="0.001" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Quantité disponible</label>
                        <input type="number" @bind="_currentActif.QuantiteDisponible" class="form-control" step="1" min="0" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Description</label>
                        <textarea @bind="_currentActif.Description" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseActifModal">Annuler</button>
                    <button class="btn btn-primary" @onclick="SaveActif" disabled="@_savingActif">
                        @if (_savingActif) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Enregistrer
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<RadzenNotification />

@code {
    bool _loading = true;
    bool _saving;
    bool _isAdmin = false;
    List<Actif> _actifs = new();
    List<Actif> _actifsFiltres = new();
    string _search = "";
    string _typeFiltre = "";

    Actif? _actifSelectionne;
    TypeTransaction _modeTransaction;
    float _prixTransaction;
    float _quantiteTransaction = 1f;
    StatutTransaction _statutTransaction = StatutTransaction.Confirmee;
    string _notesTransaction = "";
    string _erreurModal = "";

    Investisseur? _investisseur;
    
    // Admin CRUD
    bool _showActifModal = false;
    bool _isEditActif = false;
    bool _savingActif = false;
    string _actifErrorMessage = "";
    Actif _currentActif = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var user = auth.User;
        var uid = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        
        _isAdmin = user.IsInRole("Administrateur");
        
        if (uid != null)
            _investisseur = await InvestisseurSvc.GetInvestisseurByUserIdAsync(uid);

        await LoadActifs();
        _loading = false;
    }
    
    private async Task LoadActifs()
    {
        _actifs = await ActifSvc.GetActifsAsync();
        _actifsFiltres = _actifs;
        StateHasChanged();
    }

    void OnSearchInput(ChangeEventArgs e) { _search = e.Value?.ToString() ?? ""; FiltrerActifs(); }

    void FiltrerActifs()
    {
        _actifsFiltres = _actifs
            .Where(a =>
                (string.IsNullOrEmpty(_search) || a.Nom.Contains(_search, StringComparison.OrdinalIgnoreCase) || a.Symbole.Contains(_search, StringComparison.OrdinalIgnoreCase))
                && (string.IsNullOrEmpty(_typeFiltre) || a.Type.ToString() == _typeFiltre)
            ).ToList();
    }

    void ResetFiltres() { _search = ""; _typeFiltre = ""; FiltrerActifs(); }

    void OuvrirModalAchat(Actif actif)
    {
        _actifSelectionne = actif;
        _modeTransaction = TypeTransaction.Achat;
        _prixTransaction = actif.PrixActuel;
        _quantiteTransaction = 1f;
        _erreurModal = "";
    }

    void OuvrirModalVente(Actif actif)
    {
        _actifSelectionne = actif;
        _modeTransaction = TypeTransaction.Vente;
        _prixTransaction = actif.PrixActuel;
        _quantiteTransaction = 1f;
        _erreurModal = "";
    }

    void FermerModal() { _actifSelectionne = null; _erreurModal = ""; }

    async Task ValiderTransaction()
    {
        if (_investisseur == null) { _erreurModal = "Profil investisseur introuvable."; return; }
        if (_prixTransaction <= 0 || _quantiteTransaction <= 0) { _erreurModal = "Prix et quantité doivent être positifs."; return; }

        float montant = _prixTransaction * _quantiteTransaction;
        if (_modeTransaction == TypeTransaction.Achat && montant > _investisseur.BudgetDisponible)
        {
            _erreurModal = $"Budget insuffisant. Disponible : {_investisseur.BudgetDisponible.ToString("F2")} DT";
            return;
        }

        _saving = true;
        try
        {
            var tx = new Transaction
            {
                InvestisseurId = _investisseur.InvestisseurId,
                ActifId = _actifSelectionne!.Id,
                Type = _modeTransaction,
                Quantite = _quantiteTransaction,
                PrixUnitaire = _prixTransaction,
                MontantTotal = montant,
                Statut = _statutTransaction,
                Notes = _notesTransaction
            };
            await TransactionSvc.AjouterTransactionAsync(tx);

            _investisseur = await InvestisseurSvc.GetInvestisseurByUserIdAsync(
                (await AuthState.GetAuthenticationStateAsync())
                    .User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "");

            Notify.Notify(NotificationSeverity.Success, "Succès", $"Transaction {_modeTransaction} confirmée !");
            FermerModal();
        }
        catch (Exception ex)
        {
            _erreurModal = ex.Message;
        }
        _saving = false;
    }
    
    // Admin CRUD Methods
    void OpenCreateModal()
    {
        _currentActif = new Actif();
        _isEditActif = false;
        _actifErrorMessage = "";
        _showActifModal = true;
    }

    void OpenEditModal(Actif actif)
    {
        _currentActif = new Actif
        {
            Id = actif.Id,
            Symbole = actif.Symbole,
            Nom = actif.Nom,
            Type = actif.Type,
            PrixActuel = actif.PrixActuel,
            PrixAchatMoyen = actif.PrixAchatMoyen,
            QuantiteDisponible = actif.QuantiteDisponible,
            Description = actif.Description
        };
        _isEditActif = true;
        _actifErrorMessage = "";
        _showActifModal = true;
    }

    void CloseActifModal()
    {
        _showActifModal = false;
        _currentActif = new Actif();
    }

    async Task SaveActif()
    {
        if (string.IsNullOrWhiteSpace(_currentActif.Symbole) || string.IsNullOrWhiteSpace(_currentActif.Nom))
        {
            _actifErrorMessage = "Le symbole et le nom sont requis.";
            return;
        }

        _savingActif = true;
        try
        {
            if (_isEditActif)
            {
                await ActifSvc.ModifierActifAsync(_currentActif);
                Notify.Notify(NotificationSeverity.Success, "Succès", $"Actif {_currentActif.Symbole} modifié");
            }
            else
            {
                await ActifSvc.AjouterActifAsync(_currentActif);
                Notify.Notify(NotificationSeverity.Success, "Succès", $"Actif {_currentActif.Symbole} créé");
            }
            await LoadActifs();
            CloseActifModal();
        }
        catch (Exception ex)
        {
            _actifErrorMessage = ex.Message;
        }
        _savingActif = false;
    }

    async Task DeleteActif(Actif actif)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", $"Supprimer définitivement {actif.Symbole} - {actif.Nom} ?\nAttention: Les transactions liées seront également supprimées.");
        if (confirm)
        {
            await ActifSvc.SupprimerActifAsync(actif.Id);
            Notify.Notify(NotificationSeverity.Success, "Supprimé", $"Actif {actif.Symbole} supprimé");
            await LoadActifs();
        }
    }
}