@page "/actifs"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@inject IActifService ActifSvc
@inject ITransactionService TransactionSvc
@inject IInvestisseurService InvestisseurSvc
@inject AuthenticationStateProvider AuthState
@inject NotificationService Notify
@inject IJSRuntime JS

<PageTitle>Actifs — Portefeuille</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-briefcase-fill me-2 text-primary"></i>Gestion des actifs
    </h4>
    @if (_isAdmin)
    {
        <button class="btn btn-primary" @onclick="OpenCreateModal">
            <i class="bi bi-plus-circle me-1"></i>Nouvel actif
        </button>
    }
</div>

<!-- Bandeau indicateur de rôle -->
@if (_isAdmin)
{
    <div class="alert alert-success mb-3">
        <i class="bi bi-shield-lock-fill me-2"></i>
        <strong>Mode Administrateur</strong> - Vous pouvez créer, modifier et supprimer des actifs
    </div>
}
else
{
    <div class="alert alert-info mb-3">
        <i class="bi bi-person me-2"></i>
        <strong>Mode Investisseur</strong> - Vous pouvez acheter et vendre des actifs
    </div>
}

<!-- Filtres de recherche -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <input @bind="_search" @bind:event="oninput" class="form-control" placeholder="Rechercher par nom ou symbole..." />
            </div>
            <div class="col-md-4">
                <select @bind="_typeFiltre" class="form-select">
                    <option value="">Tous les types</option>
                    @foreach (var t in Enum.GetValues<TypeActif>())
                    {
                        <option value="@t">@t</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100" @onclick="ResetFiltres">
                    <i class="bi bi-x-circle me-1"></i>Reset
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Grille des actifs -->
@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (_actifsFiltres.Count == 0)
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-search fs-1 d-block mb-2"></i>
        Aucun actif trouvé.
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var actif in _actifsFiltres)
        {
            <div class="col-sm-6 col-lg-4 col-xl-3">
                <div class="card h-100 shadow-sm">
                    @if (_isAdmin)
                    {
                        <div class="card-header bg-white text-end border-bottom-0 pb-0">
                            <button class="btn btn-sm btn-warning me-2" @onclick="() => OpenEditModal(actif)">
                                <i class="bi bi-pencil me-1"></i>Modifier
                            </button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteActif(actif)">
                                <i class="bi bi-trash me-1"></i>Supprimer
                            </button>
                        </div>
                    }
                    <div class="card-body text-center">
                        <span class="badge bg-secondary mb-2">@actif.Type</span>
                        <h5 class="fw-bold mb-1">@actif.Symbole</h5>
                        <h6 class="text-muted mb-3">@actif.Nom</h6>
                        <div class="mb-3">
                            <span class="fs-4 fw-bold text-primary">@actif.PrixActuel.ToString("F2") DT</span>
                            @{
                                var variation = actif.PrixAchatMoyen > 0 ? ((actif.PrixActuel - actif.PrixAchatMoyen) / actif.PrixAchatMoyen * 100) : 0;
                            }
                            <span class="badge @(variation >= 0 ? "bg-success" : "bg-danger") ms-2">
                                @(variation >= 0 ? "+" : "")@variation.ToString("F2")%
                            </span>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-danger flex-grow-1" @onclick="() => OuvrirModalVente(actif)">
                                <i class="bi bi-cash-stack me-1"></i>Vendre
                            </button>
                            <button class="btn btn-sm btn-outline-success flex-grow-1" @onclick="() => OuvrirModalAchat(actif)">
                                <i class="bi bi-cart-plus me-1"></i>Acheter
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Modal Achat -->
@if (_actifSelectionne != null && _modeTransaction == "Achat")
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5); z-index: 1050">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Achat - @_actifSelectionne.Symbole</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="FermerModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_erreurModal))
                    {
                        <div class="alert alert-danger">@_erreurModal</div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Prix unitaire (DT)</label>
                        <input type="number" @bind="_prixTransaction" class="form-control" step="0.01" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Quantité</label>
                        <input type="number" @bind="_quantiteTransaction" class="form-control" step="0.0001" />
                    </div>
                    <div class="alert alert-light">
                        <strong>Montant total :</strong> @((_prixTransaction * _quantiteTransaction).ToString("F2")) DT
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="FermerModal">Annuler</button>
                    <button class="btn btn-success" @onclick="ValiderAchat" disabled="@_savingTransaction">
                        @if (_savingTransaction) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Confirmer
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Vente -->
@if (_actifSelectionne != null && _modeTransaction == "Vente")
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5); z-index: 1050">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Vente - @_actifSelectionne.Symbole</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="FermerModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_erreurModal))
                    {
                        <div class="alert alert-danger">@_erreurModal</div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Prix unitaire (DT)</label>
                        <input type="number" @bind="_prixTransaction" class="form-control" step="0.01" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Quantité</label>
                        <input type="number" @bind="_quantiteTransaction" class="form-control" step="0.0001" />
                    </div>
                    <div class="alert alert-light">
                        <strong>Montant total :</strong> @((_prixTransaction * _quantiteTransaction).ToString("F2")) DT
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="FermerModal">Annuler</button>
                    <button class="btn btn-danger" @onclick="ValiderVente" disabled="@_savingTransaction">
                        @if (_savingTransaction) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Confirmer
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Création/Modification d'actif -->
@if (_showActifModal)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5); z-index: 1060">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">@(_isEditActif ? "Modifier" : "Nouvel") actif</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseActifModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_actifErrorMessage))
                    {
                        <div class="alert alert-danger">@_actifErrorMessage</div>
                    }
                    <div class="mb-3">
                        <label class="form-label fw-bold">Symbole *</label>
                        <input type="text" @bind="_currentActif.Symbole" class="form-control" placeholder="ex: AAPL" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nom *</label>
                        <input type="text" @bind="_currentActif.Nom" class="form-control" placeholder="ex: Apple Inc." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Type</label>
                        <select @bind="_currentActif.Type" class="form-select">
                            <option value="Action">Action</option>
                            <option value="Obligation">Obligation</option>
                            <option value="ETF">ETF</option>
                            <option value="CryptoMonnaie">CryptoMonnaie</option>
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Prix actuel (DT)</label>
                            <input type="number" @bind="_currentActif.PrixActuel" class="form-control" step="0.001" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Prix achat moyen (DT)</label>
                            <input type="number" @bind="_currentActif.PrixAchatMoyen" class="form-control" step="0.001" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Quantité disponible</label>
                        <input type="number" @bind="_currentActif.QuantiteDisponible" class="form-control" step="1" min="0" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Description</label>
                        <textarea @bind="_currentActif.Description" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseActifModal">Annuler</button>
                    <button class="btn btn-primary" @onclick="SaveActif">Enregistrer</button>
                </div>
            </div>
        </div>
    </div>
}

<RadzenNotification />

@code {
    private bool _loading = true;
    private bool _savingTransaction = false;
    private bool _isAdmin = false;
    private List<Actif> _actifs = new();
    private List<Actif> _actifsFiltres = new();
    private string _search = "";
    private string _typeFiltre = "";

    // Transaction
    private Actif? _actifSelectionne;
    private string _modeTransaction = "";
    private float _prixTransaction;
    private float _quantiteTransaction = 1f;
    private string _erreurModal = "";
    private Investisseur? _investisseur;

    // Admin CRUD
    private bool _showActifModal = false;
    private bool _isEditActif = false;
    private string _actifErrorMessage = "";
    private Actif _currentActif = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;
        
        _isAdmin = user.IsInRole("Administrateur");
        
        var uid = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (uid != null)
        {
            _investisseur = await InvestisseurSvc.GetInvestisseurByUserIdAsync(uid);
        }

        await LoadActifs();
        _loading = false;
    }
    
    private async Task LoadActifs()
    {
        _actifs = await ActifSvc.GetActifsAsync();
        _actifsFiltres = _actifs.ToList();
        StateHasChanged();
    }

    private void ResetFiltres()
    {
        _search = "";
        _typeFiltre = "";
        FiltrerActifs();
    }
    
    private void FiltrerActifs()
    {
        if (string.IsNullOrEmpty(_search) && string.IsNullOrEmpty(_typeFiltre))
        {
            _actifsFiltres = _actifs.ToList();
        }
        else
        {
            _actifsFiltres = _actifs
                .Where(a => (string.IsNullOrEmpty(_search) || 
                            a.Nom.Contains(_search, StringComparison.OrdinalIgnoreCase) || 
                            a.Symbole.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
                            (string.IsNullOrEmpty(_typeFiltre) || a.Type.ToString() == _typeFiltre))
                .ToList();
        }
        StateHasChanged();
    }

    private void OuvrirModalAchat(Actif actif)
    {
        _actifSelectionne = actif;
        _modeTransaction = "Achat";
        _prixTransaction = actif.PrixActuel;
        _quantiteTransaction = 1f;
        _erreurModal = "";
    }

    private void OuvrirModalVente(Actif actif)
    {
        _actifSelectionne = actif;
        _modeTransaction = "Vente";
        _prixTransaction = actif.PrixActuel;
        _quantiteTransaction = 1f;
        _erreurModal = "";
    }

    private void FermerModal()
    {
        _actifSelectionne = null;
        _erreurModal = "";
    }

    private async Task ValiderAchat()
    {
        if (_investisseur == null)
        {
            _erreurModal = "Profil investisseur introuvable.";
            return;
        }
        
        if (_prixTransaction <= 0 || _quantiteTransaction <= 0)
        {
            _erreurModal = "Prix et quantité doivent être positifs.";
            return;
        }
        
        float montant = _prixTransaction * _quantiteTransaction;
        if (montant > _investisseur.BudgetDisponible)
        {
            _erreurModal = $"Budget insuffisant. Disponible : {_investisseur.BudgetDisponible.ToString("F2")} DT";
            return;
        }
        
        _savingTransaction = true;
        
        try
        {
            var transaction = new Transaction
            {
                InvestisseurId = _investisseur.InvestisseurId,
                ActifId = _actifSelectionne!.Id,
                Type = TypeTransaction.Achat,
                Quantite = _quantiteTransaction,
                PrixUnitaire = _prixTransaction,
                MontantTotal = montant,
                Statut = StatutTransaction.Confirmee,
                Notes = $"Achat de {_quantiteTransaction} {_actifSelectionne.Symbole}",
                DateTransaction = DateTime.Now
            };
            
            await TransactionSvc.AjouterTransactionAsync(transaction);
            
            // Rafraîchir l'investisseur
            _investisseur = await InvestisseurSvc.GetInvestisseurByIdAsync(_investisseur.InvestisseurId);
            
            Notify.Notify(NotificationSeverity.Success, "Achat", $"Achat de {_quantiteTransaction} {_actifSelectionne.Symbole} pour {montant:F2} DT réalisé!");
            FermerModal();
        }
        catch (Exception ex)
        {
            _erreurModal = ex.Message;
        }
        finally
        {
            _savingTransaction = false;
        }
    }

    private async Task ValiderVente()
    {
        if (_investisseur == null)
        {
            _erreurModal = "Profil investisseur introuvable.";
            return;
        }
        
        if (_prixTransaction <= 0 || _quantiteTransaction <= 0)
        {
            _erreurModal = "Prix et quantité doivent être positifs.";
            return;
        }
        
        float montant = _prixTransaction * _quantiteTransaction;
        
        // Vérifier si l'investisseur possède assez de cet actif
        var transactions = await TransactionSvc.GetTransactionsByInvestisseurAsync(_investisseur.InvestisseurId);
        var actifTransactions = transactions.Where(t => t.ActifId == _actifSelectionne!.Id);
        float quantitePossedee = actifTransactions.Sum(t => t.Type == TypeTransaction.Achat ? t.Quantite : -t.Quantite);
        
        if (_quantiteTransaction > quantitePossedee)
        {
            _erreurModal = $"Quantité insuffisante. Vous possédez {quantitePossedee} {_actifSelectionne.Symbole}";
            return;
        }
        
        _savingTransaction = true;
        
        try
        {
            var transaction = new Transaction
            {
                InvestisseurId = _investisseur.InvestisseurId,
                ActifId = _actifSelectionne!.Id,
                Type = TypeTransaction.Vente,
                Quantite = _quantiteTransaction,
                PrixUnitaire = _prixTransaction,
                MontantTotal = montant,
                Statut = StatutTransaction.Confirmee,
                Notes = $"Vente de {_quantiteTransaction} {_actifSelectionne.Symbole}",
                DateTransaction = DateTime.Now
            };
            
            await TransactionSvc.AjouterTransactionAsync(transaction);
            
            // Rafraîchir l'investisseur
            _investisseur = await InvestisseurSvc.GetInvestisseurByIdAsync(_investisseur.InvestisseurId);
            
            Notify.Notify(NotificationSeverity.Success, "Vente", $"Vente de {_quantiteTransaction} {_actifSelectionne.Symbole} pour {montant:F2} DT réalisée!");
            FermerModal();
        }
        catch (Exception ex)
        {
            _erreurModal = ex.Message;
        }
        finally
        {
            _savingTransaction = false;
        }
    }

    // Admin Methods
    private void OpenCreateModal()
    {
        _currentActif = new Actif();
        _isEditActif = false;
        _actifErrorMessage = "";
        _showActifModal = true;
    }

    private void OpenEditModal(Actif actif)
    {
        _currentActif = new Actif
        {
            Id = actif.Id,
            Symbole = actif.Symbole,
            Nom = actif.Nom,
            Type = actif.Type,
            PrixActuel = actif.PrixActuel,
            PrixAchatMoyen = actif.PrixAchatMoyen,
            QuantiteDisponible = actif.QuantiteDisponible,
            Description = actif.Description
        };
        _isEditActif = true;
        _actifErrorMessage = "";
        _showActifModal = true;
    }

    private void CloseActifModal()
    {
        _showActifModal = false;
        _currentActif = new Actif();
    }

    private async Task SaveActif()
    {
        if (string.IsNullOrWhiteSpace(_currentActif.Symbole) || string.IsNullOrWhiteSpace(_currentActif.Nom))
        {
            _actifErrorMessage = "Le symbole et le nom sont requis.";
            return;
        }

        try
        {
            if (_isEditActif)
            {
                await ActifSvc.ModifierActifAsync(_currentActif);
                Notify.Notify(NotificationSeverity.Success, "Succès", $"Actif {_currentActif.Symbole} modifié");
            }
            else
            {
                await ActifSvc.AjouterActifAsync(_currentActif);
                Notify.Notify(NotificationSeverity.Success, "Succès", $"Actif {_currentActif.Symbole} créé");
            }
            await LoadActifs();
            CloseActifModal();
        }
        catch (Exception ex)
        {
            _actifErrorMessage = ex.Message;
        }
    }

    private async Task DeleteActif(Actif actif)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", $"Supprimer {actif.Symbole} - {actif.Nom} ?");
        if (confirm)
        {
            await ActifSvc.SupprimerActifAsync(actif.Id);
            Notify.Notify(NotificationSeverity.Success, "Supprimé", $"Actif {actif.Symbole} supprimé");
            await LoadActifs();
        }
    }
}