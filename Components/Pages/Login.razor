@page "/login"
@attribute [AllowAnonymous]

<PageTitle>Connexion — Portefeuille</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-graph-up-arrow text-primary fs-1"></i>
                    <h4 class="mt-2 fw-bold">Connexion</h4>
                    <p class="text-muted small">Accédez à votre portefeuille</p>
                </div>

                @if (!string.IsNullOrEmpty(Error))
                {
                    <div class="alert alert-danger py-2">
                        <i class="bi bi-exclamation-triangle me-2"></i>@Error
                    </div>
                }
                @if (!string.IsNullOrEmpty(Success))
                {
                    <div class="alert alert-success py-2">
                        <i class="bi bi-check-circle me-2"></i>@Success
                    </div>
                }

                <form method="post" action="/api/auth/login" data-enhance="false">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input type="email" name="email" class="form-control" placeholder="votre@email.com" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Mot de passe</label>
                        <input type="password" name="password" class="form-control" placeholder="••••••••" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
                    </button>
                </form>

                <hr class="my-3" />
                <div class="text-center small">
                    Pas encore de compte ?
                    <a href="/signup" class="text-primary text-decoration-none fw-semibold">S'inscrire</a>
                </div>
                <div class="text-center mt-2 small text-muted">
                    Compte démo : <code>demo@portefeuille.com</code> / <code>Demo123!</code>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery] public string? Success { get; set; }
}
