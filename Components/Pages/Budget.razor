@page "/budget"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using PortefeuilleInvestissement.Models
@inject IInvestisseurService InvestisseurSvc
@inject AuthenticationStateProvider AuthState
@inject NotificationService Notify
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Budget — Portefeuille</PageTitle>

<h4 class="fw-bold mb-4">
    <i class="bi bi-wallet2 me-2 text-warning"></i>Budget d'investissement
</h4>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-warning" role="status"></div>
    </div>
}
else if (_isAdmin)
{
    <!-- Vue Admin : Liste de tous les investisseurs -->
    <div class="card shadow-sm">
        <div class="card-header bg-white fw-semibold">
            <i class="bi bi-people-fill me-2"></i>Tous les budgets des investisseurs
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Investisseur</th>
                            <th>Budget total (DT)</th>
                            <th>Budget disponible (DT)</th>
                            <th>Budget investi (DT)</th>
                            <th>Utilisation</th>
                            <th>Points fidélité</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in _allInvestisseurs)
                        {
                            var user = _users.FirstOrDefault(u => u.Id == inv.UserId);
                            var budgetInvesti = inv.BudgetTotal - inv.BudgetDisponible;
                            var tauxUtilisation = inv.BudgetTotal > 0 
                                ? ((inv.BudgetTotal - inv.BudgetDisponible) / inv.BudgetTotal) * 100f 
                                : 0f;
                            <tr>
                                <td>
                                    <strong>@user?.Prenom @user?.Nom</strong><br />
                                    <small class="text-muted">@user?.Email</small>
                                </td>
                                <td class="text-end">@inv.BudgetTotal.ToString("F2") DT</td>
                                <td class="text-end">@inv.BudgetDisponible.ToString("F2") DT</td>
                                <td class="text-end">@budgetInvesti.ToString("F2") DT</td>
                                <td>
                                    <div class="progress" style="height:6px">
                                        <div class="progress-bar @(tauxUtilisation > 90 ? "bg-danger" : tauxUtilisation > 70 ? "bg-warning" : "bg-success")" 
                                             style="width:@tauxUtilisation%"></div>
                                    </div>
                                    <small>@tauxUtilisation.ToString("F0")%</small>
                                </td>
                                <td class="text-end">@inv.PointsFidelite</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else if (_investisseur == null)
{
    <div class="alert alert-warning">Profil investisseur introuvable. Veuillez contacter un administrateur.</div>
}
else
{
    <!-- Vue normale pour les investisseurs -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <KpiCard Label="Budget total alloué"
                     Value="@_budgetTotalFormatted"
                     Icon="bi-bank2"
                     IconBg="#fff8e1" IconColor="#f57f17" />
        </div>
        <div class="col-md-4">
            <KpiCard Label="Budget disponible"
                     Value="@_budgetDisponibleFormatted"
                     Icon="bi-cash-coin"
                     IconBg="#e8f5e9" IconColor="#2e7d32" />
        </div>
        <div class="col-md-4">
            <KpiCard Label="Budget investi"
                     Value="@_budgetInvestiFormatted"
                     Icon="bi-graph-up"
                     IconBg="#e3f2fd" IconColor="#1565c0" />
        </div>
    </div>

    <!-- Barre d'utilisation du budget -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between mb-2">
                <span class="fw-semibold">Utilisation du budget</span>
                <span class="text-muted small">@_tauxUtilisation.ToString("F1")% investi</span>
            </div>
            <div class="progress" style="height:16px; border-radius:8px">
                <div class="progress-bar @(_tauxUtilisation > 90 ? "bg-danger" : _tauxUtilisation > 70 ? "bg-warning" : "bg-success")"
                     style="width:@_tauxUtilisation%;border-radius:8px">
                </div>
            </div>
            <div class="d-flex justify-content-between mt-1">
                <small class="text-muted">0 DT</small>
                <small class="text-muted">@_investisseur.BudgetTotal.ToString("F0") DT</small>
            </div>
        </div>
    </div>

    <!-- Allouer du budget -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white fw-semibold pt-3 border-bottom-0">
            <i class="bi bi-plus-circle text-success me-2"></i>Allouer un budget supplémentaire
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(_erreur))
            {
                <div class="alert alert-danger py-2">@_erreur</div>
            }
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Montant (DT)</label>
                    <input type="number" @bind="_montantAllocation" class="form-control" min="1" step="100" placeholder="ex: 5000" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Description</label>
                    <input type="text" @bind="_descriptionAllocation" class="form-control" placeholder="ex: Dépôt bancaire mensuel" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-success w-100" @onclick="AllouerBudget" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Allouer
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Historique des allocations -->
    <div class="card shadow-sm">
        <div class="card-header bg-white fw-semibold pt-3 border-bottom-0">
            <i class="bi bi-clock-history text-secondary me-2"></i>Historique des allocations
        </div>
        <div class="card-body p-0">
            @if (_historique.Count == 0)
            {
                <p class="text-muted text-center py-4">Aucune allocation enregistrée.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th class="text-end">Montant</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in _historique)
                            {
                                <tr>
                                    <td><small class="text-muted">@b.DateCreation.ToString("dd/MM/yyyy HH:mm")</small></td>
                                    <td class="text-end fw-semibold text-success">+@b.Montant.ToString("F2") DT</td>
                                    <td>@b.Description</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

<RadzenNotification />

@code {
    private bool _loading = true;
    private bool _saving = false;
    private bool _isAdmin = false;
    
    private Investisseur? _investisseur;
    private List<BudgetInvestissement> _historique = new();
    private List<Investisseur> _allInvestisseurs = new();
    private List<ApplicationUser> _users = new();
    
    private float _montantAllocation;
    private string _descriptionAllocation = "";
    private string _erreur = "";
    private float _tauxUtilisation = 0;
    
    private string _budgetTotalFormatted => _investisseur?.BudgetTotal.ToString("F2") + " DT" ?? "0 DT";
    private string _budgetDisponibleFormatted => _investisseur?.BudgetDisponible.ToString("F2") + " DT" ?? "0 DT";
    private string _budgetInvestiFormatted => _investisseur != null 
        ? (_investisseur.BudgetTotal - _investisseur.BudgetDisponible).ToString("F2") + " DT" 
        : "0 DT";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var user = auth.User;
            var uid = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            
            _isAdmin = user.IsInRole("Administrateur");
            
            if (_isAdmin)
            {
                _allInvestisseurs = await InvestisseurSvc.GetAllInvestisseursAsync();
                _users = UserManager.Users.ToList();
            }
            else if (uid != null)
            {
                _investisseur = await InvestisseurSvc.GetInvestisseurByUserIdAsync(uid);
                if (_investisseur != null)
                {
                    _historique = await InvestisseurSvc.GetHistoriqueBudgetsAsync(_investisseur.InvestisseurId);
                    if (_investisseur.BudgetTotal > 0)
                    {
                        _tauxUtilisation = ((_investisseur.BudgetTotal - _investisseur.BudgetDisponible) / _investisseur.BudgetTotal) * 100f;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task AllouerBudget()
    {
        if (_montantAllocation <= 0)
        {
            _erreur = "Le montant doit être supérieur à 0.";
            return;
        }
        
        _saving = true;
        _erreur = "";
        float montantAlloue = _montantAllocation;
        
        try
        {
            await InvestisseurSvc.AllouerBudgetAsync(_investisseur!.InvestisseurId, _montantAllocation, _descriptionAllocation);
            
            _investisseur = await InvestisseurSvc.GetInvestisseurByIdAsync(_investisseur.InvestisseurId);
            _historique = await InvestisseurSvc.GetHistoriqueBudgetsAsync(_investisseur!.InvestisseurId);
            
            if (_investisseur.BudgetTotal > 0)
            {
                _tauxUtilisation = ((_investisseur.BudgetTotal - _investisseur.BudgetDisponible) / _investisseur.BudgetTotal) * 100f;
            }
            
            _montantAllocation = 0;
            _descriptionAllocation = "";
            
            Notify.Notify(NotificationSeverity.Success, "Budget alloué", $"{montantAlloue:F2} DT ajouté à votre budget !");
        }
        catch (Exception ex)
        {
            _erreur = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}