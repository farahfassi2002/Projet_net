@page "/transactions"
@attribute [Authorize]
@inject ITransactionService TransactionSvc
@inject IInvestisseurService InvestisseurSvc
@inject IActifService ActifSvc
@inject AuthenticationStateProvider AuthState
@inject NotificationService Notify
@inject IJSRuntime JS

<PageTitle>Transactions — Portefeuille</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-arrow-left-right me-2 text-primary"></i>Historique des opérations
    </h4>
</div>

<!-- Filtres -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <input @bind="_searchSymbole" @bind:event="oninput"
                       class="form-control" placeholder="🔍 Symbole ou nom…" />
            </div>
            <div class="col-md-3">
                <select @bind="_filtreType" class="form-select">
                    <option value="">Tous types</option>
                    <option value="Achat">Achat</option>
                    <option value="Vente">Vente</option>
                </select>
            </div>
            <div class="col-md-3">
                <select @bind="_filtreStatut" class="form-select">
                    <option value="">Tous statuts</option>
                    <option value="Confirmee">Confirmée</option>
                    <option value="En_attente">En attente</option>
                    <option value="Annulee">Annulée</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-primary w-100" @onclick="Filtrer">
                    <i class="bi bi-funnel me-1"></i>Filtrer
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Résumé rapide -->
@if (_transactions.Any())
{
    <div class="row g-3 mb-4">
        <div class="col-6">
            <div class="card text-center border-0 bg-success bg-opacity-10">
                <div class="card-body py-2">
                    <div class="fw-bold text-success fs-5">@_transactions.Count(t => t.Type == TypeTransaction.Achat)</div>
                    <small class="text-muted">Achats</small>
                </div>
            </div>
        </div>
        <div class="col-6">
            <div class="card text-center border-0 bg-danger bg-opacity-10">
                <div class="card-body py-2">
                    <div class="fw-bold text-danger fs-5">@_transactions.Count(t => t.Type == TypeTransaction.Vente)</div>
                    <small class="text-muted">Ventes</small>
                </div>
            </div>
        </div>
    </div>
}

<!-- Tableau -->
@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Actif</th>
                            <th>Type</th>
                            <th>Quantité</th>
                            <th>Prix unitaire (DT)</th>
                            <th>Montant total (DT)</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in _transactions)
                        {
                            var actif = _actifs.FirstOrDefault(a => a.Id == t.ActifId);
                            <tr>
                                <td>@t.DateTransaction.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <strong>@(actif?.Symbole ?? "?")</strong><br />
                                    <small class="text-muted">@(actif?.Nom ?? "Inconnu")</small>
                                </td>
                                <td>
                                    <span class="badge @(t.Type == TypeTransaction.Achat ? "bg-success" : "bg-danger")">
                                        @t.Type
                                    </span>
                                </td>
                                <td>@t.Quantite.ToString("N4")</td>
                                <td>@t.PrixUnitaire.ToString("F3") DT</td>
                                <td class="fw-bold">@t.MontantTotal.ToString("F2") DT</td>
                                <td>
                                    <span class="badge @(t.Statut == StatutTransaction.Confirmee ? "bg-success" : t.Statut == StatutTransaction.En_attente ? "bg-warning" : "bg-secondary")">
                                        @t.Statut
                                    </span>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-danger" @onclick="() => SupprimerTransaction(t)">
                                        <i class="bi bi-trash me-1"></i>Supprimer
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<RadzenNotification />

@code {
    private bool _loading = true;
    private List<Transaction> _transactions = new();
    private List<Actif> _actifs = new();
    private Investisseur? _investisseur;
    private string _searchSymbole = "";
    private string _filtreType = "";
    private string _filtreStatut = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var uid = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (uid != null)
        {
            _investisseur = await InvestisseurSvc.GetInvestisseurByUserIdAsync(uid);
        }

        _actifs = await ActifSvc.GetActifsAsync();
        await ChargerTransactions();
        _loading = false;
    }

    private async Task ChargerTransactions()
    {
        if (_investisseur == null) return;

        TypeTransaction? type = null;
        if (_filtreType == "Achat") type = TypeTransaction.Achat;
        else if (_filtreType == "Vente") type = TypeTransaction.Vente;
        
        StatutTransaction? statut = null;
        if (_filtreStatut == "Confirmee") statut = StatutTransaction.Confirmee;
        else if (_filtreStatut == "En_attente") statut = StatutTransaction.En_attente;
        else if (_filtreStatut == "Annulee") statut = StatutTransaction.Annulee;
        
        _transactions = await TransactionSvc.RechercherTransactionsAsync(_investisseur.InvestisseurId, type, statut, _searchSymbole);
    }

    private async Task Filtrer()
    {
        await ChargerTransactions();
    }

    private async Task SupprimerTransaction(Transaction t)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", "Supprimer cette transaction ?");
        if (confirm)
        {
            await TransactionSvc.SupprimerTransactionAsync(t.Id);
            await ChargerTransactions();
            Notify.Notify(NotificationSeverity.Warning, "Supprimé", "Transaction supprimée.");
        }
    }
}